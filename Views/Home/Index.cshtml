@model Portfolio.Models.PortfolioViewModel
@{
    ViewData["Title"] = Model.About.Name;
}

<!-- ════════════════════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════════════════ -->
<section id="hero" class="hero-section d-flex align-items-center">
    <div class="hero-bg-shapes" aria-hidden="true">
        <span class="shape shape-1"></span>
        <span class="shape shape-2"></span>
        <span class="shape shape-3"></span>
    </div>
    <div class="container">
        <div class="row align-items-center gy-5">
            <div class="col-lg-7 hero-text">
                <p class="hero-greeting mb-2">
                    <span class="badge text-bg-primary px-3 py-2">
                        <i class="bi bi-terminal me-1"></i> Available for hire
                    </span>
                </p>
                <h1 class="display-3 fw-bold mb-3">
                    Hi, I'm <span class="text-gradient">@Model.About.Name</span>
                </h1>
                <p class="hero-subtitle fs-4 mb-4">@Model.About.Title</p>
                <p class="hero-summary text-muted mb-5">@Model.About.Shortsummary</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#projects" class="btn btn-primary btn-lg px-4">
                        View My Work <i class="bi bi-arrow-down ms-1"></i>
                    </a>
                    <a href="@Model.About.ResumeUrl" class="btn btn-outline-secondary btn-lg px-4" download>
                        <i class="bi bi-download me-1"></i> Resume
                    </a>
                </div>
                <!-- Social links -->
                <div class="hero-socials mt-5 d-flex gap-3">
                    @if (!string.IsNullOrEmpty(Model.About.Social.GitHub))
                    {
                        <a href="@Model.About.Social.GitHub" target="_blank" class="social-btn" aria-label="GitHub">
                            <i class="bi bi-github"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.About.Social.LinkedIn))
                    {
                        <a href="@Model.About.Social.LinkedIn" target="_blank" class="social-btn" aria-label="LinkedIn">
                            <i class="bi bi-linkedin"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.About.Social.Twitter))
                    {
                        <a href="@Model.About.Social.Twitter" target="_blank" class="social-btn" aria-label="Twitter / X">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-5 text-center">
                <div class="hero-avatar-wrapper">
                    <img src="@Model.About.AvatarUrl"
                         alt="@Model.About.Name"
                         class="hero-avatar img-fluid rounded-circle"
                         width="280" height="280" />
                    <div class="avatar-ring" aria-hidden="true"></div>
                    <!-- Floating badges -->
                    <div class="floating-badge badge-1">
                        <i class="bi bi-star-fill text-warning"></i> .NET Developer
                    </div>
                    <div class="floating-badge badge-2">
                        <i class="bi bi-lightning-charge-fill text-primary"></i> 5+ Years Exp
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════════════════
     ABOUT SECTION
════════════════════════════════════════════════════════ -->
<section id="about" class="section-padding bg-light">
    <div class="container">
        <div class="section-header text-center mb-5">
            <span class="section-tag">Who am I?</span>
            <h2 class="section-title">About Me</h2>
        </div>
        <div class="row align-items-center gy-5">
            <div class="col-lg-5 text-center">
                <div class="about-img-wrapper">
                    <img src="@Model.About.AvatarUrl"
                         alt="@Model.About.Name"
                         class="img-fluid rounded-4 shadow-lg"
                         width="380" />
                </div>
            </div>
            <div class="col-lg-7">
                <h3 class="fw-bold mb-1">@Model.About.Name</h3>
                <p class="text-primary fw-semibold mb-4">@Model.About.Title</p>
                <p class="lead text-muted mb-4">@Model.About.Summary</p>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="about-info-item">
                            <i class="bi bi-envelope-fill text-primary me-2"></i>
                            <a href="mailto:@Model.Contact.Email">@Model.Contact.Email</a>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="about-info-item">
                            <i class="bi bi-telephone-fill text-primary me-2"></i>
                            <span>@Model.Contact.Phone</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="about-info-item">
                            <i class="bi bi-geo-alt-fill text-primary me-2"></i>
                            <span>@Model.Contact.Location</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="about-info-item">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="text-success fw-semibold">Available for work</span>
                        </div>
                    </div>
                </div>

                <a href="@Model.About.ResumeUrl" class="btn btn-primary px-4" download>
                    <i class="bi bi-download me-2"></i>Download Resume
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════════════════
     PROJECTS SECTION
════════════════════════════════════════════════════════ -->
<section id="projects" class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5">
            <span class="section-tag">What I've built</span>
            <h2 class="section-title">Projects</h2>
        </div>

        <!-- Filter buttons -->
        <div class="text-center mb-5">
            <div class="btn-group project-filter" role="group">
                <button type="button" class="btn btn-outline-primary active" data-filter="all">All</button>
                <button type="button" class="btn btn-outline-primary" data-filter="featured">Featured</button>
            </div>
        </div>

        <div class="row g-4" id="projectsGrid">
            @foreach (var project in Model.Projects)
            {
                <div class="col-md-6 col-xl-6 project-item @(project.IsFeatured ? "is-featured" : "")">
                    <div class="card project-card h-100 border-0 shadow-sm">
                        @if (project.IsFeatured)
                        {
                            <div class="project-featured-badge">
                                <i class="bi bi-star-fill me-1"></i>Featured
                            </div>
                        }
                        <div class="project-img-wrapper">
                            <img src="@project.ImageUrl"
                                 alt="@project.Title"
                                 class="card-img-top"
                                 loading="lazy" />
                            <div class="project-overlay">
                                <a href="@project.LiveUrl" class="btn btn-light btn-sm me-2" target="_blank">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>Live Demo
                                </a>
                                <a href="@project.GitHubUrl" class="btn btn-outline-light btn-sm" target="_blank">
                                    <i class="bi bi-github me-1"></i>Source
                                </a>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold mb-2">@project.Title</h5>
                            <p class="card-text text-muted small mb-3">@project.Description</p>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var tag in project.Tags)
                                {
                                    <span class="badge tag-badge">@tag</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════════════════
     SKILLS SECTION
════════════════════════════════════════════════════════ -->
<section id="skills" class="section-padding bg-light">
    <div class="container">
        <div class="section-header text-center mb-5">
            <span class="section-tag">What I know</span>
            <h2 class="section-title">Skills</h2>
        </div>
        <div class="row g-4">
            @foreach (var category in Model.SkillCategories)
            {
                <div class="col-lg-4">
                    <div class="skills-card card border-0 shadow-sm h-100 p-4">
                        <div class="skills-card-header mb-4">
                            <div class="skills-icon">
                                <i class="bi @category.Icon"></i>
                            </div>
                            <h5 class="fw-bold mb-0">@category.Category</h5>
                        </div>
                        <div class="skill-list">
                            @foreach (var skill in category.Skills)
                            {
                                <div class="skill-item mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="skill-name small fw-semibold">@skill.Name</span>
                                        <span class="skill-pct small text-muted">@skill.Proficiency%</span>
                                    </div>
                                    <div class="progress skill-progress" role="progressbar"
                                         aria-label="@skill.Name"
                                         aria-valuenow="@skill.Proficiency" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar" style="width: 0%"
                                             data-width="@skill.Proficiency%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════════════════
     CONTACT SECTION
════════════════════════════════════════════════════════ -->
<section id="contact" class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5">
            <span class="section-tag">Get in touch</span>
            <h2 class="section-title">Contact</h2>
        </div>

        @if (TempData["ContactSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["ContactSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ContactError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ContactError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-5">
            <!-- Info cards -->
            <div class="col-lg-4">
                <div class="d-flex flex-column gap-4">
                    <div class="contact-info-card card border-0 shadow-sm p-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="contact-icon">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <div>
                                <p class="text-muted small mb-0">Email</p>
                                <a href="mailto:@Model.Contact.Email" class="fw-semibold text-dark text-decoration-none">
                                    @Model.Contact.Email
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="contact-info-card card border-0 shadow-sm p-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="contact-icon">
                                <i class="bi bi-telephone-fill"></i>
                            </div>
                            <div>
                                <p class="text-muted small mb-0">Phone</p>
                                <a href="tel:@Model.Contact.Phone" class="fw-semibold text-dark text-decoration-none">
                                    @Model.Contact.Phone
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="contact-info-card card border-0 shadow-sm p-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="contact-icon">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <div>
                                <p class="text-muted small mb-0">Location</p>
                                <span class="fw-semibold">@Model.Contact.Location</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact form -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm p-4 p-lg-5">
                    <form asp-action="Contact" asp-controller="Home" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
                                <input type="text" name="Name" class="form-control" placeholder="John Doe" required />
                                <div class="invalid-feedback">Please enter your name.</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                                <input type="email" name="Email" class="form-control" placeholder="john@example.com" required />
                                <div class="invalid-feedback">Please enter a valid email.</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
                                <input type="text" name="Subject" class="form-control" placeholder="Project inquiry…" required />
                                <div class="invalid-feedback">Please enter a subject.</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
                                <textarea name="Message" class="form-control" rows="5"
                                          placeholder="Tell me about your project…" required></textarea>
                                <div class="invalid-feedback">Please enter a message.</div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg px-5">
                                    <i class="bi bi-send-fill me-2"></i>Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
